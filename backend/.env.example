# Copy to .env and fill in. NEVER commit the real .env.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me

# Supabase project (Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Optional legacy HS256 secret. Leave blank to validate sessions through Supabase Auth.
SUPABASE_JWT_SECRET=

# Supabase Postgres (Settings -> Database -> Connection string, use the
# "Session pooler" URI on Railway). Format:
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/cloud9

# Comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:5173

# Payments (PayFast sandbox values for dev)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# Where PayFast redirects the browser back to (frontend URL)
FRONTEND_URL=http://localhost:5173

# Server-side AI car comparison (never expose this key to the frontend)
OPENAI_API_KEY=
OPENAI_COMPARE_MODEL=gpt-5.6-terra
