# Copy to .env.local and fill in (Supabase Dashboard -> Settings -> API).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the browser-safe publishable key (or legacy anon key).
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Leave empty in dev (vite proxies /api to localhost:5000).
# In production set to the Railway backend URL, e.g. https://cloud9-api.up.railway.app
VITE_API_BASE_URL=
